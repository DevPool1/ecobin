# ============================================
# ECOBIN — Variáveis de Ambiente
# ============================================
# Copiar para .env e preencher:
#   cp .env.example .env
# ============================================

# --- Google Gemini API ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# --- MQTT Broker (Mosquitto no RPi) ---
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_CLIENT_ID=ecobin-gateway
MQTT_USERNAME=
MQTT_PASSWORD=

# --- ESP32-CAM ---
# IP da ESP32-CAM na rede local (hotspot do telemóvel)
ESP32_CAM_IP=192.168.4.2
ESP32_CAM_PORT=80
CAPTURE_TIMEOUT=5
CAPTURE_RETRIES=3

# --- Wi-Fi (referência para os firmwares) ---
# Para apresentação em sala: usar hotspot do telemóvel
WIFI_SSID=ECOBIN_Hotspot
WIFI_PASSWORD=ecobin2026

# --- Base de Dados ---
DATABASE_PATH=./database/ecobin.db

# --- Imagens ---
SAVE_IMAGES=true
IMAGES_DIR=./captured_images

# --- Web Dashboard (fase posterior) ---
WEB_HOST=0.0.0.0
WEB_PORT=5000
WEB_DEBUG=false

# --- Logging ---
LOG_LEVEL=INFO
