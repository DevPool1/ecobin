# ============================================
# ECOBIN — Variáveis de Ambiente (.env.example)
# ============================================
# Copiar para .env e preencher com os valores reais:
#   cp .env.example .env
# ============================================

# --- Google Gemini API ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- MQTT Broker ---
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# --- Wi-Fi (para referência) ---
WIFI_SSID=your_wifi_ssid
WIFI_PASSWORD=your_wifi_password

# --- Web Dashboard ---
WEB_HOST=0.0.0.0
WEB_PORT=5000
WEB_DEBUG=false

# --- Base de Dados ---
DATABASE_PATH=./database/ecobin.db
